JWT_SECRET=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Initial admin (seeded only when the user table is empty).
# Required in production — the dev default (admin@office.local / admin123) is
# refused when NODE_ENV=production.
ADMIN_EMAIL=
ADMIN_PASSWORD=
WEBHOOK_API_KEY=your-webhook-api-key-here
DATABASE_URL="file:./dev.db"

# Server (production): PORT defaults to 4000; CORS_ORIGIN defaults to the Vite
# dev server. When the backend serves frontend/dist (same origin), leave
# CORS_ORIGIN unset.
PORT=
CORS_ORIGIN=

# WhatsApp integration (Phase 2)
# WHATSAPP_PROVIDER: cloud (Meta Cloud API, default) | mock (local dev, no external calls)
WHATSAPP_PROVIDER=cloud
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# WhatsApp automation engine (Phase 2b)
# AUTOMATION_ENABLED: true enables the 5-minute ScheduledMessage dispatch tick; unset/false keeps the engine dormant
AUTOMATION_ENABLED=true
